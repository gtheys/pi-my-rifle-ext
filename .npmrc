# AIDEV-NOTE: legacy-peer-deps is required because this repo aliases the pi
# packages (@mariozechner/* -> npm:@earendil-works/*) and the upstream pi
# ecosystem pins peer deps with caret-on-zero ranges (e.g. ^0.74.0, which npm
# treats as >=0.74.0 <0.75.0). Those ranges break on every minor bump of the
# 0.x fork, making npm's peer resolution unusable here. All peer packages are
# verified to resolve physically under node_modules/ (both alias names point at
# the same installed files), so skipping the peer gate is safe for this repo.
legacy-peer-deps=true
