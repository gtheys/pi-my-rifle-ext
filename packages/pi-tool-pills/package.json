{
  "name": "@gtheys/pi-tool-pills",
  "version": "0.1.0",
  "description": "Pi extension — coloured pill badges for tool calls and Shiki-powered syntax-highlighted diffs for write/edit",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
